# Copy to .github-deploy-secrets.env (gitignored) and fill in.
# Requires: gh auth login (gh secret set 会负责加密上传)
# Then: bash scripts/push-github-env-secrets.sh
# Resume (skip existing): default. Overwrite all: bash scripts/push-github-env-secrets.sh --force

GITHUB_REPO=FundConnectHK/documenso

# Database (passwords URL-encode if they contain @ : / ? # etc.)
STAGING_DB_PASSWORD=
PROD_DB_PASSWORD=

# SendGrid SMTP (username is literally "apikey")
SENDGRID_API_KEY=

# GCS interoperability HMAC (same bucket for both envs is OK)
GCS_HMAC_ACCESS_KEY_ID=
GCS_HMAC_SECRET_ACCESS_KEY=
GCS_BUCKET=fundconnecthk-contract-storage

NEXT_PRIVATE_SMTP_FROM_NAME=FundConnectHK
NEXT_PRIVATE_SMTP_FROM_ADDRESS=no-reply@fundconnecthk.com

# Generate with: openssl rand -base64 32  (staging — keep stable after first deploy)
STAGING_NEXTAUTH_SECRET=
STAGING_NEXT_PRIVATE_ENCRYPTION_KEY=
STAGING_NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY=

# Production — must differ from staging
PROD_NEXTAUTH_SECRET=
PROD_NEXT_PRIVATE_ENCRYPTION_KEY=
PROD_NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY=
